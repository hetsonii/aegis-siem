# Copy this file to `.env` and fill in your AWS Academy Learner Lab credentials.
# These values rotate every session - refresh them from the Learner Lab
# "AWS Details" panel each time you start the lab.
#
# `.env` is gitignored and must never be committed. This template is safe to commit.
# Do NOT wrap values in quotes.

AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SESSION_TOKEN=your-session-token
AWS_DEFAULT_REGION=us-east-1

# Optional: email address to receive HIGH+ severity alerts. When set, running
# `terraform apply` creates an SNS email subscription and AWS sends a one-time
# confirmation email - click the link once to activate. Leave blank to disable.
# (Pass it to Terraform, e.g. `terraform apply -var "alert_email=$ALERT_EMAIL"`.)
ALERT_EMAIL=
